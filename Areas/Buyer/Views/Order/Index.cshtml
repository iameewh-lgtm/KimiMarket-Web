@model IEnumerable<iameewh.Models.OrderHeader>

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary fw-bold">QUẢN LÝ ĐƠN HÀNG</h2>
        </div>
    </div>
    <br />
    <table class="table table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên nẫu</th>
                <th>Số ĐT</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.PhoneNumber</td>
                    <td>@item.OrderDate.ToShortDateString()</td>
                    <td>@item.OrderTotal.ToString("N0") VNĐ</td>
                    <td><span class="badge bg-info">@item.OrderStatus</span></td>
                    <td>
                        <a asp-action="Details" asp-route-orderId="@item.Id" class="btn btn-primary btn-sm">CHI TIẾT</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>