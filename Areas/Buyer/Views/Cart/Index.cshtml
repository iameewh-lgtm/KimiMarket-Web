@model IEnumerable<iameewh.Models.ShoppingCart>
@{
    ViewData["Title"] = "Giỏ hàng";
    decimal totalOrderPrice = 0;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary mb-0">GIỎ HÀNG CỦA BẠN</h2>
        <a asp-area="Buyer" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th class="text-center">Số lượng</th>
                                <th>Thành tiền</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var price = item.Product.Price;
                                var totalItemPrice = price * item.Count;
                                totalOrderPrice += totalItemPrice;

                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center py-2">
                                            <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="rounded me-3 shadow-sm" style="width: 70px; height: 70px; object-fit: cover;" onerror="this.src='/images/no-image.png'" />
                                            <a asp-area="Buyer" asp-controller="Home" asp-action="Details" asp-route-productId="@item.ProductId" class="fw-bold text-dark text-decoration-none">@item.Product.Name</a>
                                        </div>
                                    </td>
                                    <td class="text-danger fw-bold">@price.ToString("N0") ₫</td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm" role="group">
                                            <a asp-action="Minus" asp-route-cartId="@item.Id" class="btn btn-outline-secondary btn-sm px-3"><i class="bi bi-dash"></i></a>
                                            <span class="btn btn-outline-secondary btn-sm disabled px-3 text-dark fw-bold">@item.Count</span>
                                            <a asp-action="Plus" asp-route-cartId="@item.Id" class="btn btn-outline-secondary btn-sm px-3"><i class="bi bi-plus"></i></a>
                                        </div>
                                    </td>
                                    <td class="text-danger fw-bold">@totalItemPrice.ToString("N0") ₫</td>
                                    <td class="text-center">
                                        <a asp-action="Remove" asp-route-cartId="@item.Id" class="btn btn-danger btn-sm shadow-sm"><i class="bi bi-trash"></i> Xóa</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white d-flex justify-content-end align-items-center p-4 border-top">
                    <div class="text-end">
                        <h5 class="fw-bold mb-3 text-muted">Tổng thanh toán: <span class="text-danger fs-3 ms-2">@totalOrderPrice.ToString("N0") ₫</span></h5>
                        <a asp-area="Buyer" asp-controller="Order" asp-action="Checkout" class="btn btn-primary fw-bold px-5 py-2 shadow-sm">Tiến hành đặt hàng</a>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
                    <h4 class="mt-4 fw-bold text-muted">Giỏ hàng của bạn đang trống</h4>
                    <p class="text-muted mb-4">Có vẻ như bạn chưa thêm sản phẩm nào vào giỏ hàng.</p>
                    <a asp-area="Buyer" asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">Mua sắm ngay</a>
                </div>
            }
        </div>
    </div>
</div>