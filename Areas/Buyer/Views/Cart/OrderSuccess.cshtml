@model int

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center p-5 shadow-sm bg-white rounded border-top border-success border-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            <h1 class="text-success fw-bold mt-4">ĐẶT HÀNG THÀNH CÔNG!</h1>
            <h4 class="mt-3">Cảm ơn bạn đã mua sắm tại ADU VIP.</h4>

            <div class="alert alert-success mt-4 fs-5" role="alert">
                Mã đơn hàng của bạn là: <strong>#@Model</strong>
            </div>

            <p class="text-muted mt-3">
                Chúng tôi đã gửi một email xác nhận đến địa chỉ email của bạn kèm theo chi tiết đơn hàng.
                Đơn hàng sẽ được xử lý và giao đến bạn trong thời gian sớm nhất.
            </p>

            <div class="mt-4 pt-3 border-top">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success me-2 py-2 px-4 fw-bold">
                    <i class="bi bi-cart-plus"></i> Tiếp tục mua sắm
                </a>
                <a asp-controller="Order" asp-action="Index" class="btn btn-success py-2 px-4 fw-bold">
                    <i class="bi bi-list-check"></i> Xem lịch sử đơn hàng
                </a>
            </div>
        </div>
    </div>
</div>