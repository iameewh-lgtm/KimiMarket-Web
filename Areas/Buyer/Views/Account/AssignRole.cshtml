@model List<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Phân quyền người dùng";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white py-3">
            <h4 class="mb-0 text-uppercase">Phân quyền cho: @ViewBag.UserName</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="UpdateRole" method="post">
                <input type="hidden" name="userId" value="@ViewBag.UserId" />

                <div class="mb-4">
                    <label class="form-label fw-bold">Chọn vai trò mới cho tài khoản:</label>
                    <select name="roleName" class="form-select border-2">
                        @foreach (var role in Model)
                        {
                            if (role.Name == ViewBag.CurrentRole)
                            {
                                <option value="@role.Name" selected>@role.Name (Hiện tại)</option>
                            }
                            else
                            {
                                <option value="@role.Name">@role.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Cập nhật quyền</button>
                    <a asp-action="UserList" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>