@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center p-5 shadow-sm bg-white rounded">
            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 5rem;"></i>
            <h1 class="text-danger fw-bold mt-3">TỪ CHỐI TRUY CẬP</h1>
            <h5 class="mt-3">Bạn không có quyền truy cập vào khu vực này.</h5>
            <p class="text-muted mt-3">
                Trang bạn đang cố gắng truy cập yêu cầu đặc quyền cao hơn. Vui lòng đăng nhập bằng tài khoản có vai trò phù hợp.
            </p>
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary me-2">Quay lại trang chủ</a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Đăng nhập tài khoản khác</a>
            </div>
        </div>
    </div>
</div>