@model iameewh.Models.LoginVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống - KIMI MARKET</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .card-login {
            border-radius: 15px;
            border: none;
            max-width: 400px;
            margin-top: 100px;
        }

        .btn-login {
            background-color: #0d6efd;
            color: white;
            border: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card shadow card-login mx-auto">
                    <div class="card-body p-5">
                        <h2 class="text-center mb-4 fw-bold text-primary">ĐĂNG NHẬP</h2>
                        <form asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                            <div class="form-floating mb-3">
                                <input asp-for="Email" class="form-control" placeholder="Email" />
                                <label asp-for="Email">Địa chỉ Email</label>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu" />
                                <label asp-for="Password">Mật khẩu</label>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="form-check mb-3">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label class="form-check-label" asp-for="RememberMe">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>

                            <button type="submit" class="btn btn-login w-100 py-2 shadow-sm mb-3">Đăng nhập</button>
                        </form>

                        <div class="text-center small">
                            <p class="mb-1">Chưa có tài khoản? <a asp-action="Register" class="text-decoration-none fw-bold">Đăng ký ngay</a></p>
                            <p class="mb-0"><a asp-action="ForgotPassword" class="text-muted text-decoration-none">Quên mật khẩu?</a></p>
                            <hr />
                            <a href="/" class="text-secondary text-decoration-none"><i class="bi bi-house"></i> Quay lại trang chủ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>