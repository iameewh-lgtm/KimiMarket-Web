@model iameewh.Models.Category

<form method="post" asp-action="Delete">
    <input asp-for="Id" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Xóa Danh Mục</h2>
            <hr />
        </div>
        <div class="mb-3">
            <label asp-for="Name">Tên danh mục</label>
            <input asp-for="Name" disabled class="form-control" />
        </div>
        <button type="submit" class="btn btn-danger" style="width:150px">Xóa luôn</button>
        <a asp-controller="Category" asp-action="Index" class="btn btn-secondary" style="width:150px">Quay Lại</a>
    </div>
</form>