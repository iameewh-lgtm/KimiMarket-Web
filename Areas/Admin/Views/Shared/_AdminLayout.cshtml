<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KIMI Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            display: flex;
            min-height: 100vh;
            flex-direction: column;
        }

        .wrapper {
            display: flex;
            flex: 1;
        }

        #sidebar {
            min-width: 250px;
            max-width: 250px;
            background: #343a40;
            color: #fff;
            transition: all 0.3s;
        }

            #sidebar .sidebar-header {
                padding: 20px;
                background: #212529;
            }

            #sidebar ul p {
                color: #fff;
                padding: 10px;
            }

            #sidebar ul li a {
                padding: 10px 20px;
                font-size: 1.1em;
                display: block;
                color: #ced4da;
                text-decoration: none;
            }

                #sidebar ul li a:hover {
                    color: #fff;
                    background: #495057;
                }

        #content {
            width: 100%;
            padding: 20px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand text-warning fw-bold" asp-area="Buyer" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-arrow-left-circle"></i> Về trang KIMI MARKET
                </a>
                <div class="navbar-text text-white">
                    Xin chào Quản trị viên!
                </div>
            </div>
        </nav>
    </header>

    <div class="wrapper">
        <nav id="sidebar" class="shadow-sm">
            <div class="sidebar-header text-center">
                <h4 class="fw-bold mb-0">HỆ THỐNG QUẢN TRỊ</h4>
            </div>
            <ul class="list-unstyled components mt-3">
                <li>
                    <a asp-area="Admin" asp-controller="Admin" asp-action="Dashboard">
                        <i class="bi bi-speedometer2 me-2"></i> Bảng điều khiển
                    </a>
                </li>
                <li>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index">
                        <i class="bi bi-tags me-2"></i> Quản lý Danh mục
                    </a>
                </li>
                <li>
                    <a asp-area="Admin" asp-controller="Slider" asp-action="Index">
                        <i class="bi bi-images me-2"></i> Quản lý Banner
                    </a>
                </li>
                <li>
                    <a asp-area="Admin" asp-controller="User" asp-action="Index">
                        <i class="bi bi-people me-2"></i> Quản lý Người dùng
                    </a>
                </li>
                <hr class="text-secondary mx-3" />
                <li>
                    <a asp-area="Seller" asp-controller="Product" asp-action="Index" class="text-info">
                        <i class="bi bi-box-seam me-2"></i> Xem kho Sản phẩm
                    </a>
                </li>
            </ul>
        </nav>

        <div id="content" class="bg-light">
            <main role="main" class="pb-3">
                <partial name="_Notification" />
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>