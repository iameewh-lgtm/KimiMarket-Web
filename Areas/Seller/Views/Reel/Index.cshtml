@model IEnumerable<iameewh.Models.Reel>

<div class="container bg-white p-4 shadow-sm mt-4 rounded border">
    <div class="row align-items-center mb-4">
        <div class="col-6">
            <h3 class="fw-bold mb-0" style="color: #ff5000;">QUẢN LÝ KIMI REELS</h3>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Reel" asp-action="Upsert" class="btn text-white fw-bold shadow-sm" style="background-color: #ff5000;">
                <i class="bi bi-plus-circle"></i> ĐĂNG VIDEO MỚI
            </a>
        </div>
    </div>

    <table class="table table-hover align-middle shadow-sm rounded overflow-hidden">
        <thead class="table-light">
            <tr>
                <th width="30%">Tiêu đề Video</th>
                <th width="30%">Sản phẩm gắn kèm</th>
                <th width="20%">Ngày đăng</th>
                <th width="20%" class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var obj in Model)
                {
                    <tr>
                        <td class="fw-bold text-dark">@obj.Title</td>
                        <td>
                            <span class="badge bg-warning text-dark fs-6">@obj.Product.Name</span>
                        </td>
                        <td>@obj.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Upsert" asp-route-id="@obj.Id" class="btn btn-outline-primary btn-sm mx-1 rounded">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@obj.Id" class="btn btn-outline-danger btn-sm mx-1 rounded" onclick="return confirm('Nẫu có chắc muốn xóa clip này hông?');">
                                    <i class="bi bi-trash-fill"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">Chưa có cái video nào hết trơn, đăng liền đi nẫu!</td>
                </tr>
            }
        </tbody>
    </table>
</div>