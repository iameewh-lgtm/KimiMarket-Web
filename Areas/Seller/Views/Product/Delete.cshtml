@model iameewh.Models.Product

<form method="post" asp-action="Delete">
    <input asp-for="Id" hidden />
    
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Xóa Sản Phẩm Này?</h2>
            <hr />
        </div>
        
        <div class="row">
            <div class="col-10">
                <div class="mb-3">
                    <label asp-for="Name">Tên sản phẩm</label>
                    <input asp-for="Name" disabled class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Price">Giá tiền</label>
                    <input asp-for="Price" disabled class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="CategoryId">Danh mục</label>
                    <input asp-for="Category.Name" disabled class="form-control" />
                </div>
            </div>
            <div class="col-2">
                @if (Model.ImageUrl != null)
                {
                    <img src="@Model.ImageUrl" width="100%" style="border-radius:5px; border:1px solid #bbb9b9" />
                }
            </div>
        </div>

        <button type="submit" class="btn btn-danger" style="width:150px">Xóa luôn</button>
        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary" style="width:150px">Quay Lại</a>
    </div>
</form>