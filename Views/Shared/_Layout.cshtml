<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KIMI MARKET</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container">
                <a class="navbar-brand text-primary fw-bold" asp-area="Buyer" asp-controller="Home" asp-action="Index" style="color: #ff5000 !important;">KIMI MARKET</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link text-dark fw-bold" asp-area="Buyer" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-bold" asp-area="Buyer" asp-controller="Home" asp-action="Reels">Video Reels</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-bold" asp-area="Buyer" asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                    </ul>

                    <div class="d-flex align-items-center">
                        <form asp-area="Buyer" asp-controller="Home" asp-action="Index" method="get" class="me-3">
                            <input type="text" name="searchString" placeholder="Tìm sản phẩm..." class="form-control form-control-sm" />
                        </form>

                        @* Hiển thị Đăng xuất nếu đã đăng nhập, Đăng nhập nếu chưa *@
                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="me-3 fw-bold text-dark">Chào, @User.Identity.Name</span>
                            <form asp-area="Buyer" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger fw-bold me-2">Đăng xuất</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-primary fw-bold me-2" asp-area="Buyer" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            <a class="btn btn-sm btn-primary fw-bold me-2" asp-area="Buyer" asp-controller="Account" asp-action="Register" style="background-color: #ff5000; border-color: #ff5000;">Đăng ký</a>
                        }

                        @* Hiện nút Quản trị nếu user là Admin *@
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="btn btn-sm btn-dark fw-bold" asp-area="Admin" asp-controller="Admin" asp-action="Dashboard">Quản trị</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>